# ── JPortfolio Dashboard — environment template ──
# Copy to .env.local for local development. NEVER commit .env.local.

# Set to "true" only on your local machine to enable upload / reconcile / chat / amendments.
# Leave unset / "false" on Netlify so the hosted site runs dashboard-only.
JPORTFOLIO_IS_LOCAL=true

# Absolute path to the Obsidian vault that holds the portfolio statement folders.
JPORTFOLIO_VAULT_PATH=C:\Users\nilan\OneDrive\Brain\JPortfolio
JPORTFOLIO_PORTFOLIO_1_FOLDER=JSAF
JPORTFOLIO_PORTFOLIO_2_FOLDER=Ind

# Python interpreter used to run the local reconciliation engine (hybrid model).
# e.g. "python", "python3", or a full path. Only needed locally.
PYTHON_BIN=python

# LLM provider for chat + clarifications. One of: openai | anthropic | manual
LLM_PROVIDER=anthropic
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Market pricing (Yahoo Finance) — runs in both local and hosted modes.
YAHOO_FINANCE_ENABLED=true

# ── Hosted access control (Netlify) ──
# Simple shared-secret basic auth enforced by middleware.ts on the hosted site.
# Set both on Netlify. Leave blank locally to skip the prompt.
DASHBOARD_AUTH_USER=
DASHBOARD_AUTH_PASSWORD=
